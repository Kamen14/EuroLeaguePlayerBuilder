@using EuroLeaguePlayerBuilder.ViewModels.Arenas
@model DeleteArenaViewModel
@{
    ViewData["Title"] = "Delete Arena";
}
<div class="container mt-5">
    <div class="bg-dark text-white">
        <div class="card-body">
            <h3 class="card-title text-warning">Confirm Delete</h3>
            <p>Are you sure you want to delete arena <strong>@Model.Name</strong> in <strong>@Model.City</strong>?</p>
            <form asp-action="Delete" asp-controller="Arenas" method="post">
                <button type="submit" class="btn btn-danger me-2">Delete</button>
                <a asp-controller="Arenas" asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>

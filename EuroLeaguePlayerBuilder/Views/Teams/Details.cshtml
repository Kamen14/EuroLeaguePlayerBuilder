@using EuroLeaguePlayerBuilder.ViewModels.Teams
@model TeamDetailsViewModel

@{
    ViewData["Title"] = "Team Details";
}

<div class="container py-5">
    <div class="row g-4 align-items-start">
        <!-- Team Logo -->
        <div class="col-12 col-md-3 text-center">
            <img src="@Model.LogoPath"
                 alt="@Model.Name Logo"
                 class="img-fluid mb-3"
                 style="max-height:150px; object-fit:contain;">
            <h2 class="text-orange">@Model.Name</h2>
        </div>
        

        <!-- Coach, Players and Arena -->
        <div class="col-12 col-md-9">
            <p class="text-white-50 mb-3"><small>Arena: @Model.ArenaName — @Model.ArenaCapacity seats</small></p>

            <!-- Coach Table -->
			<partial name="_CoachPartial" model="Model.Coach" />

            <!-- Players Table -->
            <partial name="_PlayerPartial" model="Model.Players" />
            }
        </div>
    </div>
</div>

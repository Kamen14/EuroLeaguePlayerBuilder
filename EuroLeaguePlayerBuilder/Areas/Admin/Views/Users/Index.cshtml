@using EuroLeaguePlayerBuilder.ViewModels.Admin
@model IEnumerable<AdminManageUserViewModel>
@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-4">
    <h1 class="mb-4">User Management</h1>

    <table class="table table-dark table-bordered table-hover">
        <thead>
            <tr style="color: darkorange;">
                <th>Email</th>
                <th>Nickname</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody style="color: white;">
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>@(user.Nickname ?? "-")</td>
                    <td class="text-orange">@user.Role</td>
                    <td>
                        @if (user.Role != "Admin")
                        {
                            <a asp-area="Admin" asp-controller="Users"
                               asp-action="PromoteToAdmin" asp-route-id="@user.Id"
                               class="btn btn-sm"
                               style="background-color: darkorange; color: black; font-weight: bold;">
                                Promote to Admin
                            </a>
                        }
                        else
                        {
                            <a asp-area="Admin" asp-controller="Users"
                               asp-action="DemoteToUser" asp-route-id="@user.Id"
                               class="btn btn-sm btn-outline-secondary">
                                Demote to User
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

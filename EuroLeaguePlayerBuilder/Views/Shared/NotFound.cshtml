@{
    ViewData["Title"] = "Page Not Found";
}
<div class="container py-5 text-center">
    <h1 class="text-orange" style="font-size: 6rem;">404</h1>
    <h2 class="text-white mb-4">Page Not Found</h2>
    <p class="text-secondary mb-4">The page you are looking for does not exist.</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-warning">Go Home</a>
</div>

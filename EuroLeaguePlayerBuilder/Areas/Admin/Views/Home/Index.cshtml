@using EuroLeaguePlayerBuilder.ViewModels.Admin
@{
    ViewData["Title"] = "Admin Dashboard";
}
@model AdminDashboardViewModel

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <h1 class="mb-0">Admin Dashboard</h1>
        <a asp-area="Admin" asp-controller="Users" asp-action="Index"
           class="btn" style="background-color: darkorange; color: black; font-weight: bold;">
            Manage Users
        </a>
    </div>
    <p class="mb-4" style="color: white;">Welcome, @User.Identity!.Name</p>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card text-center shadow-sm" style="background-color: #2a2a2a; border: 1px solid darkorange;">
                <div class="card-body">
                    <h5 class="card-title" style="color: white;">Players</h5>
                    <p class="display-4 fw-bold text-orange">@Model.TotalPlayers</p>
                    <a asp-area="Admin" asp-controller="Players" asp-action="Index"
                       class="btn btn-sm" style="background-color: darkorange; color: black; font-weight: bold;">
                        Manage Players
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center shadow-sm" style="background-color: #2a2a2a; border: 1px solid darkorange;">
                <div class="card-body">
                    <h5 class="card-title" style="color: white;">Arenas</h5>
                    <p class="display-4 fw-bold text-orange">@Model.TotalArenas</p>
                    <a asp-area="Admin" asp-controller="Arenas" asp-action="Index"
                       class="btn btn-sm" style="background-color: darkorange; color: black; font-weight: bold;">
                        Manage Arenas
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center shadow-sm" style="background-color: #2a2a2a; border: 1px solid darkorange;">
                <div class="card-body">
                    <h5 class="card-title" style="color: white;">Games</h5>
                    <p class="display-4 fw-bold text-orange">@Model.TotalGames</p>
                    <a asp-area="Admin" asp-controller="Games" asp-action="Index"
                       class="btn btn-sm" style="background-color: darkorange; color: black; font-weight: bold;">
                        Manage Games
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>